    <ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/Code">
      <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
        <Content>AppChipWrap(
  children: CategoriaActividad.values.map((cat) {
    final selected = _controller.categorias.contains(cat);
    return AppFilterChip(
      label: cat.label,
      selected: selected,
      onSelected: (_) =&gt; setState(() =&gt;
        _controller.toggleCategoria(cat)),
    );
  }).toList(),
)</Content>
      </CharacterStyleRange>
      <Br/>
    </ParagraphStyleRange>
