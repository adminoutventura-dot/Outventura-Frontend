      </CharacterStyleRange>
      <Br/>
    </ParagraphStyleRange>
    <ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/IndexEntry">
      <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
