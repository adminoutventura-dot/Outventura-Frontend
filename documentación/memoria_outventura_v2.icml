    <ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/Code">
      <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
        <Content>src/
├── main.ts           ← Bootstrap, CORS, ValidationPipe, Swagger
├── app.module.ts     ← Importa tots els mòduls
├── prisma/           ← PrismaService (global)
├── auth/             ← Login amb JWT + bcrypt
├── role/             ← CRUD de rols
├── user/             ← CRUD d'usuaris
├── category/         ← CRUD de categories
├── activity/         ← CRUD d'activitats + categories
├── equipment/        ← CRUD d'equipament + categories
└── equipment-status/ ← CRUD d'estats de material</Content>
      </CharacterStyleRange>
      <Br/>
    </ParagraphStyleRange>
