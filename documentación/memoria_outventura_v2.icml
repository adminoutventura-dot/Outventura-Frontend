      </CharacterStyleRange>
      <Br/>
    </ParagraphStyleRange>
    <ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/ImagePlaceholder">
      <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
        <Content>[ IMAGEN: MOCKUPS: Sol·licituds + Detall sol·licitud + Formulari sol·licitud ]</Content>
      </CharacterStyleRange>
      <Br/>
    </ParagraphStyleRange>
    <ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/ImagePlaceholder">
      <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
