    <ParagraphStyleRange AppliedParagraphStyle="ParagraphStyle/Code">
      <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/$ID/[No character style]">
        <Content>lib/
├── main.dart              ← ProviderScope, MaterialApp, tema
├── app/theme/             ← AppColors, AppTextStyles, AppTheme
├── catalog/               ← Design system intern
├── core/
│   ├── network/           ← ApiDelay, AuthStorage, DioClient
│   ├── utils/             ← DateFormatter, FormValidators, IdGenerator
│   └── widgets/           ← 14 widgets reutilitzables
├── features/
│   ├── auth/              ← Login, perfil, providers
│   ├── outventura/        ← 12 pantalles + 5 formularis
│   └── preferences/       ← Tema clar/fosc</Content>
